# ============================================================
# Homelab Docker Stack - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.
# ============================================================

# --- Host ---
DOCKER_USER=aruiot
DOCKER_BASE=/home/aruiot/docker

# --- Home Assistant ---
HA_PORT=8123
HA_NAME=arunivas
# Location for sun/weather. Replace with YOUR coordinates (gitignored in .env).
HA_LATITUDE=12.3456789
HA_LONGITUDE=80.1234567
HA_ELEVATION=10
HA_TIMEZONE=Asia/Kolkata
HA_COUNTRY=IN
HA_CURRENCY=INR
HA_UNIT_SYSTEM=metric
# Mains voltage for energy calculations (India=220, US=120, EU=230)
HA_MAINS_VOLTAGE=220

# --- MQTT (Mosquitto) ---
MQTT_PORT=1883
MQTT_WS_PORT=9001
# Broker address as seen from the HA container (host network = Pi LAN IP).
MQTT_BROKER=10.1.0.6
# MQTT credentials — MUST match the mosquitto pwfile you create in Quick Start.
MQTT_USERNAME=aru-mqtt
MQTT_PASSWORD=changeme-mqtt-password
# MQTT topic prefixes used by IoT devices
# These must match what your device firmware publishes to.
MQTT_PREFIX_1=kk
MQTT_PREFIX_2=sai-nivas

# --- Portainer ---
PORTAINER_PORT=9000
